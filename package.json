{
  "name": "plugins-nuvio",
  "version": "1.1.1",
  "description": "Providers francais pour Nuvio et site Madrador Film hebergeable.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node site/server.js",
    "start:web": "node site/server.js",
    "manifest:update": "node scripts/update-manifest.js",
    "check": "node --check site/server.js && node --check scripts/test-providers.js",
    "test:providers": "node scripts/test-providers.js",
    "test:quick": "node scripts/test-providers.js --only=frenchstream,movix,nakios --timeout=45000"
  },
  "engines": {
    "node": ">=18"
  }
}
